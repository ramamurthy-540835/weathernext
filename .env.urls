# WeatherNext v3 — URL Configuration
# Manage old URL, new frontend, and new backend URLs

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔵 OLD URL (UNTOUCHED - Backward Compatibility)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OLD_FRONTEND_URL=https://your-old-domain.com
OLD_API_BASE_URL=https://your-old-domain.com/api
OLD_WEBSOCKET_URL=wss://your-old-domain.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟢 NEW FRONTEND URL (Production v3)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_FRONTEND_URL=https://weathernext-dashboard-v3.run.app
NEXT_PUBLIC_FRONTEND_NAME=WeatherNext Dashboard v3
NEXT_PUBLIC_APP_REGION=UAE

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟡 NEW BACKEND API URL (Separate Service)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_API_BASE_URL=https://api.weathernext-uae.ncm.ae
NEXT_PUBLIC_API_VERSION=v3
NEXT_PUBLIC_API_TIMEOUT=30000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔴 LOCAL DEVELOPMENT (Used when running npm run dev)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_LOCAL_FRONTEND=http://localhost:3000
NEXT_PUBLIC_LOCAL_API=http://localhost:3000/api

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📊 FEATURE FLAGS (v3)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_ENABLE_15DAY_FORECAST=true
NEXT_PUBLIC_ENABLE_CONFIDENCE_VISUALIZATION=true
NEXT_PUBLIC_ENABLE_UAE_ALERT_SCAN=true
NEXT_PUBLIC_ENABLE_ENSEMBLE_VIEW=true
NEXT_PUBLIC_ENABLE_ARCHITECTURE_DOCS=true
NEXT_PUBLIC_ENABLE_TAIL_RISK_ANALYSIS=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 GEMINI 3.1 PRO CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_GEMINI_MODEL=gemini-3.1-pro-preview
NEXT_PUBLIC_GEMINI_FEATURES=full-ensemble,15-day,tail-risk,confidence-metrics

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌍 DEPLOYMENT TARGETS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Deployment mode: development | staging | production
NEXT_PUBLIC_DEPLOYMENT_MODE=local
NEXT_PUBLIC_DEPLOYMENT_REGION=us-central1
NEXT_PUBLIC_DEPLOYMENT_PLATFORM=cloud-run

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📍 DEFAULT LOCATION (UAE)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_DEFAULT_LAT=25.2
NEXT_PUBLIC_DEFAULT_LON=55.27
NEXT_PUBLIC_DEFAULT_LOCATION_NAME=Dubai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🛡️ SECURITY & HEADERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_CORS_ORIGIN=https://api.weathernext-uae.ncm.ae

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 VERSION & BUILD INFO
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_VERSION=3.0.0
NEXT_PUBLIC_BUILD_TYPE=v3-production
NEXT_PUBLIC_LLM=Gemini 3.1 Pro Preview
NEXT_PUBLIC_ENSEMBLE_MEMBERS=64
NEXT_PUBLIC_FORECAST_DAYS=15
NEXT_PUBLIC_NCM_SYSTEM=WeatherNext 2.0 Decision Intelligence
