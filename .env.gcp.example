# GCP Cloud Run environment — set via Secret Manager + --set-env-vars
# DO NOT commit actual values — this is just a reference template

# GCP (auto-configured on Cloud Run — no need to set)
# GOOGLE_APPLICATION_CREDENTIALS — NOT needed, Cloud Run uses ADC automatically
GOOGLE_CLOUD_PROJECT=ctoteam
GCP_PROJECT_ID=ctoteam

# BigQuery
BIGQUERY_PROJECT_ID=ctoteam
BIGQUERY_DATASET=weathernext_2
BIGQUERY_TABLE=weathernext_2_0_0

# WeatherNext
WEATHERNEXT_INIT_DATE=auto
WEATHERNEXT_LAT_MIN=12.90
WEATHERNEXT_LAT_MAX=13.10
WEATHERNEXT_LON_MIN=80.20
WEATHERNEXT_LON_MAX=80.30
WEATHERNEXT_MAX_HOURS=120

# Gemini (via Secret Manager)
GEMINI_API_KEY=via-secret-manager
GOOGLE_API_KEY=via-secret-manager
GEMINI_MODEL_NAME=gemini-2.0-flash

# Mapbox (via Secret Manager)
NEXT_PUBLIC_MAPBOX_TOKEN=via-secret-manager

# App
NEXT_PUBLIC_APP_NAME=WeatherNext Dashboard
NEXT_PUBLIC_APP_VERSION=2.0.0
